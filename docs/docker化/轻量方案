### 2. `backend/prisma/seed.ts`（统一种子数据）

这是你最缺的——统一的数据生成：

```typescript
import { PrismaClient, Role, ScooterStatus, HireType } from '@prisma/client';
import * as bcrypt from 'bcrypt';

const prisma = new PrismaClient();

async function main() {
  console.log('🌱 开始填充种子数据...');

  // ===== 1. 创建固定测试账号 =====
  const adminPassword = await bcrypt.hash('admin123', 10);
  const admin = await prisma.user.upsert({
    where: { email: 'admin@scooter.com' },
    update: {},
    create: {
      email: 'admin@scooter.com',
      passwordHash: adminPassword,
      role: Role.MANAGER,
      createdAt: new Date('2024-01-01'),
    },
  });
  console.log('✅ 管理员账号:', admin.email, '/ admin123');

  const userPassword = await bcrypt.hash('user123', 10);
  const user1 = await prisma.user.upsert({
    where: { email: 'test1@example.com' },
    update: {},
    create: {
      email: 'test1@example.com',
      passwordHash: userPassword,
      role: Role.CUSTOMER,
    },
  });
  console.log('✅ 测试用户1:', user1.email, '/ user123');

  const user2 = await prisma.user.upsert({
    where: { email: 'test2@example.com' },
    update: {},
    create: {
      email: 'test2@example.com',
      passwordHash: userPassword,
      role: Role.CUSTOMER,
    },
  });
  console.log('✅ 测试用户2:', user2.email, '/ user123');

  // ===== 2. 创建固定电动车数据 =====
  const scooterLocations = [
    { id: 'SC001', location: '市中心广场 - A区', battery: 85 },
    { id: 'SC002', location: '火车站 - 东出口', battery: 72 },
    { id: 'SC003', location: '购物中心 - 北门', battery: 90 },
    { id: 'SC004', location: '大学城 - 图书馆', battery: 45 },
    { id: 'SC005', location: '科技园 - 1号楼', battery: 60 },
    { id: 'SC006', location: '公园南门 - 停车场', battery: 95 },
  ];

  for (const s of scooterLocations) {
    await prisma.scooter.upsert({
      where: { id: s.id },
      update: {},
      create: {
        id: s.id,
        location: s.location,
        batteryLevel: s.battery,
        status: ScooterStatus.AVAILABLE,
      },
    });
    console.log(`✅ 电动车: ${s.id} - ${s.location}`);
  }

  // ===== 3. 创建一些测试预约（可选）=====
  // 这是测试人员最需要的——有现成的数据可以测试各种状态
  const scooter = await prisma.scooter.findFirst({ where: { id: 'SC001' } });
  if (scooter) {
    await prisma.hire.upsert({
      where: { id: 'HIRE001' },
      update: {},
      create: {
        id: 'HIRE001',
        userId: user1.id,
        scooterId: scooter.id,
        type: HireType.ONE_TIME,
        status: 'ACTIVE',
        startTime: new Date(Date.now() - 2 * 60 * 60 * 1000), // 2小时前开始
        createdAt: new Date('2024-01-15'),
      },
    });
    console.log('✅ 测试预约: HIRE001 (ACTIVE状态)');

    // 更新电动车状态为IN_USE
    await prisma.scooter.update({
      where: { id: scooter.id },
      data: { status: ScooterStatus.IN_USE },
    });
  }

  console.log('\n🎉 种子数据填充完成！');
  console.log('\n📋 可用测试账号:');
  console.log('   管理员: admin@scooter.com / admin123');
  console.log('   用户1:  test1@example.com / user123');
  console.log('   用户2:  test2@example.com / user123');
  console.log('\n📋 测试场景:');
  console.log('   - SC001: 被user1预约中 (IN_USE)');
  console.log('   - SC002~SC006: 可用 (AVAILABLE)');
}

main()
  .catch((e) => {
    console.error('❌ 种子数据失败:', e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
```

