### 5. `scripts/setup.sh`（一键启动脚本）

```bash
#!/bin/bash
set -e

echo "🚀 Scooter项目环境初始化..."

# 检查Docker
if ! command -v docker &> /dev/null; then
    echo "❌ 请先安装Docker: https://docs.docker.com/get-docker/"
    exit 1
fi

# 检查docker-compose
if ! command -v docker-compose &> /dev/null; then
    echo "❌ 请先安装docker-compose"
    exit 1
fi

# 1. 创建.env文件（如果不存在）
if [ ! -f "backend/.env" ]; then
    echo "📝 创建 backend/.env..."
    cp .env.example backend/.env
    echo "✅ 已创建 backend/.env"
fi

# 2. 启动数据库
echo "🐳 启动PostgreSQL容器..."
docker-compose up -d

# 3. 等待数据库就绪
echo "⏳ 等待数据库就绪..."
sleep 5

# 4. 进入backend目录执行迁移和种子
cd backend

echo "📊 执行数据库迁移..."
npx prisma migrate deploy

echo "🌱 填充种子数据..."
npm run seed

echo ""
echo "✅ 环境初始化完成！"
echo ""
echo "📋 下一步："
echo "   1. cd backend && npm run start:dev    # 启动后端"
echo "   2. cd frontend && npm run dev         # 启动前端（新终端）"
echo "   3. 访问 http://localhost:5173"
echo ""
echo "🔑 测试账号:"
echo "   管理员: admin@scooter.com / admin123"
echo "   用户1:  test1@example.com / user123"
echo ""
echo "💡 常用命令:"
echo "   npm run seed      # 重新填充种子数据"
echo "   npm run db:reset  # 清空数据库并重新种子"
echo "   docker-compose down  # 停止数据库"
```

