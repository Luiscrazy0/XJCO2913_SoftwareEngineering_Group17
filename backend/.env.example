# Database
DATABASE_URL="postgresql://username:password@localhost:5432/scooter_rental?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Email (SMTP Configuration)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Encryption for payment cards
ENCRYPTION_KEY="your-32-byte-encryption-key-change-in-production"

# CORS
FRONTEND_URL="http://localhost:5173"

# AMap API
# Web服务 API Key（用于 restapi.amap.com；推荐）
AMAP_WEB_KEY="your-amap-webservice-key"
# 兼容旧命名（如使用此项，代码也会读取）
# AMAP_API_KEY="your-amap-api-key"
