generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Station {
  id        String    @id @default(uuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  scooters  Scooter[]
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  role             Role              @default(CUSTOMER)
  userType         UserType          @default(NORMAL)
  bookings         Booking[]
  employeeBookings EmployeeBooking[]
  paymentCards     PaymentCard[]
}

model Scooter {
  id        String        @id @default(uuid())
  location  String
  status    ScooterStatus @default(AVAILABLE)
  latitude  Float?
  longitude Float?
  stationId String?
  updatedAt DateTime      @updatedAt
  bookings  Booking[]
  station   Station?      @relation(fields: [stationId], references: [id])
}

model Booking {
  id              String           @id @default(uuid())
  userId          String
  scooterId       String
  hireType        HireType
  originalEndTime DateTime?
  startTime       DateTime
  endTime         DateTime
  status          BookingStatus    @default(PENDING_PAYMENT)
  totalCost       Float
  extensionCount  Int              @default(0)
  extendedFrom    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  scooter         Scooter          @relation(fields: [scooterId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  employeeBooking EmployeeBooking?
  payment         Payment?
}

model Payment {
  id        String  @id @default(uuid())
  bookingId String  @unique
  amount    Float
  status    String
  booking   Booking @relation(fields: [bookingId], references: [id])
}

model PaymentCard {
  id             String   @id @default(uuid())
  userId         String
  lastFourDigits String
  expiryDate     String
  cardHolder     String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model EmployeeBooking {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  employeeId String
  guestEmail String
  guestName  String
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id])
  employee   User     @relation(fields: [employeeId], references: [id])
}

enum Role {
  CUSTOMER
  MANAGER
}

enum UserType {
  NORMAL
  STUDENT
  SENIOR
  FREQUENT
}

enum ScooterStatus {
  AVAILABLE
  UNAVAILABLE
  RENTED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  EXTENDED
}

enum HireType {
  HOUR_1
  HOUR_4
  DAY_1
  WEEK_1
}
